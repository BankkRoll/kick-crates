# ═════════════════════════════════════════════════════════════════════
# Copy this file to apps/extension/.env.local and fill in your deployment
# URLs. Vite only loads .env.local (NOT .env.example) at build time.
#
# Your URLs come from `npx convex dev` — it prints something like:
#   Convex URL:      https://<deployment>.convex.cloud   ← WebSocket endpoint
#   Convex site URL: https://<deployment>.convex.site    ← HTTP / OAuth / webhooks
# ═════════════════════════════════════════════════════════════════════

VITE_CONVEX_URL=https://<YOUR-DEPLOYMENT>.convex.cloud
VITE_CONVEX_SITE_URL=https://<YOUR-DEPLOYMENT>.convex.site
VITE_EXT_VERSION=0.1.0
